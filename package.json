{
  "name": "flext2pdf",
  "version": "1.3.3",
  "description": "A Powerful Templating Engine",
  "keywords": ["templates", "templating engine", "handlebars", "flext to pdf"],
  "repository": "https://github.com/TrustMe-kz/flext2pdf.git",
  "type": "module",
  "browser": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./index.css": "./dist/index.css"
  },
  "bin": {
    "flext2pdf": "./bin/flext2pdf.mjs"
  },
  "scripts": {
    "sync:assets": "node bin/sync-assets.mjs",
    "build:types": "tsc && tsc-alias",
    "build-only": "bin/build.mjs && npm run build:types",
    "build": "npm run sync:assets && npm run build-only",
    "prepublish": "npm run build"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "engines": {
    "node": ">=14"
  },
  "author": "Kenny Romanov",
  "license": "MIT",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@handlebars/parser": "^2.2.2",
    "@types/he": "^1.2.3",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "esbuild-plugin-import-glob": "^0.1.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@trustme24/flext": "^2.0.3"
  },
  "dependencies": {
    "chromium-bidi": "^15.0.0",
    "he": "^1.2.0",
    "playwright-core": "^1.59.1"
  }
}
